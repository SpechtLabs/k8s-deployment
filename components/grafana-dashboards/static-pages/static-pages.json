{
  "uid": "static-pages-overview",
  "title": "Static Pages / Overview",
  "description": "Golden-signals overview for the StaticPages service: page-serving proxy (Beyla http_server_*), upload API (staticpages_*), external synthetic monitoring, and Go runtime. Availability/latency SLIs align with the Static Pages SLOs.",
  "tags": ["static-pages", "spechtlabs", "application", "slo"],
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "graphTooltip": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "1m",
  "links": [
    {
      "title": "Static Pages repo",
      "type": "link",
      "icon": "external link",
      "url": "https://github.com/SpechtLabs/StaticPages",
      "targetBlank": true
    }
  ],
  "annotations": {
    "list": [
      {
        "name": "Annotations & Alerts",
        "type": "dashboard",
        "iconColor": "rgba(0, 211, 255, 1)",
        "enable": true,
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" }
      }
    ]
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data source",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1,
        "regex": ""
      },
      {
        "name": "tempo",
        "label": "Traces (Tempo)",
        "type": "datasource",
        "query": "tempo",
        "current": {},
        "hide": 0,
        "refresh": 1,
        "regex": ""
      },
      {
        "name": "cluster",
        "label": "Cluster",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(http_server_request_duration_seconds_count{service_name=\"static-pages\"}, cluster)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      },
      {
        "name": "pod",
        "label": "Pod",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(go_goroutines{job=\"static-pages\", cluster=~\"$cluster\"}, pod)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Service Health",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1
    },
    {
      "type": "stat",
      "title": "Proxy Availability (range)",
      "description": "Share of page-serving requests that did not return a 5xx, over the dashboard time range. SLI for the availability SLO. 404s count as served (valid for static hosting).",
      "id": 2,
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_request_duration_seconds_count{service_name=\"static-pages\", cluster=~\"$cluster\", http_response_status_code!~\"5..\"}[$__range])) / sum(rate(http_server_request_duration_seconds_count{service_name=\"static-pages\", cluster=~\"$cluster\"}[$__range]))"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "min": 0,
          "max": 1,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.99 }, { "color": "green", "value": 0.999 } ] }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "5xx Error Ratio (range)",
      "description": "Share of page-serving requests returning 5xx. This is the error-budget consumer for the availability SLO.",
      "id": 3,
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(http_server_request_duration_seconds_count{service_name=\"static-pages\", cluster=~\"$cluster\", http_response_status_code=~\"5..\"}[$__range])) or vector(0)) / clamp_min(sum(rate(http_server_request_duration_seconds_count{service_name=\"static-pages\", cluster=~\"$cluster\"}[$__range])), 1)"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.001 }, { "color": "red", "value": 0.01 } ] }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Synthetic Uptime (range)",
      "description": "Average of probe_success across the external Synthetic Monitoring checks for the Static Pages domains.",
      "id": 4,
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "avg(avg_over_time(probe_success{job=\"static-pages\"}[$__range]))" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "min": 0,
          "max": 1,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.99 }, { "color": "green", "value": 0.999 } ] }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Request Rate",
      "description": "Total page-serving request rate (all status codes).",
      "id": 5,
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(http_server_request_duration_seconds_count{service_name=\"static-pages\", cluster=~\"$cluster\"}[$__rate_interval]))" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2, "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Latency p99",
      "description": "99th percentile page-serving latency over the dashboard range.",
      "id": 6,
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_request_duration_seconds_bucket{service_name=\"static-pages\", cluster=~\"$cluster\"}[$__range])))" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 2.5 } ] }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Pods Up",
      "description": "Number of Static Pages pods currently scraped as up.",
      "id": 7,
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum(up{job=\"static-pages\", cluster=~\"$cluster\"})" }
      ],
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 1 }, { "color": "green", "value": 2 } ] }
        },
        "overrides": []
      }
    },

    {
      "type": "row",
      "title": "Traffic & Errors (Page Serving)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10
    },
    {
      "type": "timeseries",
      "title": "Request Rate by Status Code",
      "description": "Page-serving throughput broken down by HTTP status. 200/206/30x are healthy; 404 is a valid served response for static hosting; 5xx consume the error budget.",
      "id": 11,
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (http_response_status_code) (rate(http_server_request_duration_seconds_count{service_name=\"static-pages\", cluster=~\"$cluster\"}[$__rate_interval]))", "legendFormat": "{{http_response_status_code}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 30, "stacking": { "mode": "normal" }, "showPoints": "never", "lineWidth": 1 },
          "links": [
            {
              "title": "Explore traces for status ${__field.labels.http_response_status_code}",
              "targetBlank": true,
              "url": "/explore?schemaVersion=1&orgId=1&panes=%7B%22trace%22%3A%7B%22datasource%22%3A%22${tempo}%22%2C%22queries%22%3A%5B%7B%22refId%22%3A%22A%22%2C%22datasource%22%3A%7B%22type%22%3A%22tempo%22%2C%22uid%22%3A%22${tempo}%22%7D%2C%22queryType%22%3A%22traceql%22%2C%22query%22%3A%22%7Bresource.service.name%3D%5C%22static-pages%5C%22%20%26%26%20span.http.response.status_code%3D${__field.labels.http_response_status_code}%7D%22%2C%22limit%22%3A20%2C%22tableType%22%3A%22traces%22%7D%5D%2C%22range%22%3A%7B%22from%22%3A%22now-3h%22%2C%22to%22%3A%22now%22%7D%7D%7D"
            }
          ]
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "/5../" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byName", "options": "200" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] },
          { "matcher": { "id": "byName", "options": "404" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "type": "piechart",
      "title": "Status Code Distribution (range)",
      "description": "Relative share of status codes over the dashboard range.",
      "id": 12,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (http_response_status_code) (increase(http_server_request_duration_seconds_count{service_name=\"static-pages\", cluster=~\"$cluster\"}[$__range]))", "legendFormat": "{{http_response_status_code}}" }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["percent"] }, "pieType": "donut", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "links": [
            {
              "title": "Explore traces for status ${__field.labels.http_response_status_code}",
              "targetBlank": true,
              "url": "/explore?schemaVersion=1&orgId=1&panes=%7B%22trace%22%3A%7B%22datasource%22%3A%22${tempo}%22%2C%22queries%22%3A%5B%7B%22refId%22%3A%22A%22%2C%22datasource%22%3A%7B%22type%22%3A%22tempo%22%2C%22uid%22%3A%22${tempo}%22%7D%2C%22queryType%22%3A%22traceql%22%2C%22query%22%3A%22%7Bresource.service.name%3D%5C%22static-pages%5C%22%20%26%26%20span.http.response.status_code%3D${__field.labels.http_response_status_code}%7D%22%2C%22limit%22%3A20%2C%22tableType%22%3A%22traces%22%7D%5D%2C%22range%22%3A%7B%22from%22%3A%22now-3h%22%2C%22to%22%3A%22now%22%7D%7D%7D"
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Error Ratio over Time (4xx vs 5xx)",
      "description": "5xx is the SLO error-budget consumer (red threshold = 0.1% objective). 4xx (excluding 404) shown for context; 404 is treated as a valid served response and excluded here.",
      "id": 13,
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "(sum(rate(http_server_request_duration_seconds_count{service_name=\"static-pages\", cluster=~\"$cluster\", http_response_status_code=~\"5..\"}[$__rate_interval])) or vector(0)) / clamp_min(sum(rate(http_server_request_duration_seconds_count{service_name=\"static-pages\", cluster=~\"$cluster\"}[$__rate_interval])), 0.001)", "legendFormat": "5xx" },
        { "refId": "B", "expr": "(sum(rate(http_server_request_duration_seconds_count{service_name=\"static-pages\", cluster=~\"$cluster\", http_response_status_code=~\"4..\", http_response_status_code!=\"404\"}[$__rate_interval])) or vector(0)) / clamp_min(sum(rate(http_server_request_duration_seconds_count{service_name=\"static-pages\", cluster=~\"$cluster\"}[$__rate_interval])), 0.001)", "legendFormat": "4xx (excl 404)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineWidth": 2, "thresholdsStyle": { "mode": "line" } },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.001 } ] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byName", "options": "4xx (excl 404)" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "Request Rate by Method",
      "description": "GET dominates page serving; POST is upload traffic; HEAD/OPTIONS are probes.",
      "id": 14,
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (http_request_method) (rate(http_server_request_duration_seconds_count{service_name=\"static-pages\", cluster=~\"$cluster\"}[$__rate_interval]))", "legendFormat": "{{http_request_method}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" }, "showPoints": "never", "lineWidth": 1 },
          "links": [
            {
              "title": "Explore traces for method ${__field.labels.http_request_method}",
              "targetBlank": true,
              "url": "/explore?schemaVersion=1&orgId=1&panes=%7B%22trace%22%3A%7B%22datasource%22%3A%22${tempo}%22%2C%22queries%22%3A%5B%7B%22refId%22%3A%22A%22%2C%22datasource%22%3A%7B%22type%22%3A%22tempo%22%2C%22uid%22%3A%22${tempo}%22%7D%2C%22queryType%22%3A%22traceql%22%2C%22query%22%3A%22%7Bresource.service.name%3D%5C%22static-pages%5C%22%20%26%26%20span.http.request.method%3D%5C%22${__field.labels.http_request_method}%5C%22%7D%22%2C%22limit%22%3A20%2C%22tableType%22%3A%22traces%22%7D%5D%2C%22range%22%3A%7B%22from%22%3A%22now-3h%22%2C%22to%22%3A%22now%22%7D%7D%7D"
            }
          ]
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },

    {
      "type": "row",
      "title": "Latency",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "id": 20
    },
    {
      "type": "timeseries",
      "title": "Latency Percentiles (p50 / p90 / p99)",
      "description": "Page-serving request duration percentiles from the http_server_request_duration_seconds histogram.",
      "id": 21,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_request_duration_seconds_bucket{service_name=\"static-pages\", cluster=~\"$cluster\"}[$__rate_interval])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.90, sum by (le) (rate(http_server_request_duration_seconds_bucket{service_name=\"static-pages\", cluster=~\"$cluster\"}[$__rate_interval])))", "legendFormat": "p90" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_request_duration_seconds_bucket{service_name=\"static-pages\", cluster=~\"$cluster\"}[$__rate_interval])))", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineWidth": 2, "thresholdsStyle": { "mode": "dashed" } },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 2.5 } ] },
          "links": [
            {
              "title": "Explore slow traces (> 1s)",
              "targetBlank": true,
              "url": "/explore?schemaVersion=1&orgId=1&panes=%7B%22trace%22%3A%7B%22datasource%22%3A%22${tempo}%22%2C%22queries%22%3A%5B%7B%22refId%22%3A%22A%22%2C%22datasource%22%3A%7B%22type%22%3A%22tempo%22%2C%22uid%22%3A%22${tempo}%22%7D%2C%22queryType%22%3A%22traceql%22%2C%22query%22%3A%22%7Bresource.service.name%3D%5C%22static-pages%5C%22%20%26%26%20duration%20%3E%201s%7D%22%2C%22limit%22%3A20%2C%22tableType%22%3A%22traces%22%7D%5D%2C%22range%22%3A%7B%22from%22%3A%22now-3h%22%2C%22to%22%3A%22now%22%7D%7D%7D"
            }
          ]
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "type": "heatmap",
      "title": "Latency Heatmap",
      "description": "Distribution of page-serving request durations across histogram buckets.",
      "id": 22,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (le) (rate(http_server_request_duration_seconds_bucket{service_name=\"static-pages\", cluster=~\"$cluster\"}[$__rate_interval]))", "legendFormat": "{{le}}", "format": "heatmap" }
      ],
      "options": { "calculate": false, "cellGap": 1, "color": { "scheme": "Spectral", "mode": "scheme" }, "yAxis": { "unit": "s" } },
      "fieldConfig": { "defaults": { "custom": { "scaleDistribution": { "type": "linear" } } }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Latency SLI — Fast-Request Ratio",
      "description": "Share of requests served under 1s and under 0.5s. The < 1s line is the latency SLI (red threshold = 95% objective).",
      "id": 23,
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(http_server_request_duration_seconds_bucket{service_name=\"static-pages\", cluster=~\"$cluster\", le=\"1.0\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_request_duration_seconds_count{service_name=\"static-pages\", cluster=~\"$cluster\"}[$__rate_interval])), 0.001)", "legendFormat": "< 1s" },
        { "refId": "B", "expr": "sum(rate(http_server_request_duration_seconds_bucket{service_name=\"static-pages\", cluster=~\"$cluster\", le=\"0.5\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_request_duration_seconds_count{service_name=\"static-pages\", cluster=~\"$cluster\"}[$__rate_interval])), 0.001)", "legendFormat": "< 0.5s" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineWidth": 2, "thresholdsStyle": { "mode": "line" } },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 0.95 } ] }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },

    {
      "type": "row",
      "title": "Synthetic Monitoring (External Blackbox)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 30
    },
    {
      "type": "timeseries",
      "title": "Probe Success by Location",
      "description": "probe_success (1 = up) from the Grafana Synthetic Monitoring check against the public site, per probe location.",
      "id": 31,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "min by (probe) (probe_success{job=\"static-pages\"})", "legendFormat": "{{probe}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "fillOpacity": 20, "showPoints": "never", "lineWidth": 2, "lineInterpolation": "stepAfter" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "Probe HTTP Total Duration by Location",
      "description": "End-to-end HTTP request time observed by external probes, per location.",
      "id": 32,
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "avg by (probe) (probe_http_total_duration_seconds{job=\"static-pages\"})", "legendFormat": "{{probe}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "Probe Phase Durations",
      "description": "Where external request time is spent: connect, TLS handshake, server processing, and content transfer. Averaged across probe locations.",
      "id": 33,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "avg by (phase) (probe_http_duration_seconds{job=\"static-pages\"})", "legendFormat": "{{phase}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "bars", "fillOpacity": 70, "stacking": { "mode": "normal" }, "showPoints": "never", "lineWidth": 1 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },

    {
      "type": "row",
      "title": "Upload API (staticpages_*)",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 },
      "id": 40,
      "panels": [
        {
          "type": "timeseries",
          "title": "API Request Rate by Code / Method",
          "description": "Upload API requests instrumented by go-gin-prometheus. Low volume (CI-triggered). 403 = OIDC auth rejection (expected, not a service error).",
          "id": 41,
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 46 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            { "refId": "A", "expr": "sum by (code, method) (rate(staticpages_requests_total{cluster=~\"$cluster\"}[$__rate_interval]))", "legendFormat": "{{method}} {{code}}" }
          ],
          "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20, "showPoints": "never", "lineWidth": 1 } }, "overrides": [] },
          "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
        },
        {
          "type": "timeseries",
          "title": "API Latency p99",
          "description": "99th percentile latency of the upload API from staticpages_request_duration_seconds.",
          "id": 42,
          "gridPos": { "h": 8, "w": 6, "x": 12, "y": 46 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            { "refId": "A", "expr": "histogram_quantile(0.99, sum by (le) (rate(staticpages_request_duration_seconds_bucket{cluster=~\"$cluster\"}[$__rate_interval])))", "legendFormat": "p99" }
          ],
          "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineWidth": 2 } }, "overrides": [] },
          "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } }
        },
        {
          "type": "timeseries",
          "title": "Avg Upload Request Size",
          "description": "Mean request payload size for upload API calls.",
          "id": 43,
          "gridPos": { "h": 8, "w": 6, "x": 18, "y": 46 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            { "refId": "A", "expr": "sum(rate(staticpages_request_size_bytes_sum{cluster=~\"$cluster\"}[$__rate_interval])) / clamp_min(sum(rate(staticpages_request_size_bytes_count{cluster=~\"$cluster\"}[$__rate_interval])), 1)", "legendFormat": "avg request bytes" }
          ],
          "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineWidth": 2 } }, "overrides": [] },
          "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } }
        }
      ]
    },

    {
      "type": "row",
      "title": "Runtime & Resources",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 46 },
      "id": 50,
      "panels": [
        {
          "type": "timeseries",
          "title": "Goroutines by Pod",
          "id": 51,
          "gridPos": { "h": 8, "w": 8, "x": 0, "y": 47 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            { "refId": "A", "expr": "go_goroutines{job=\"static-pages\", cluster=~\"$cluster\", pod=~\"$pod\"}", "legendFormat": "{{pod}}" }
          ],
          "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineWidth": 1 } }, "overrides": [] },
          "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
        },
        {
          "type": "timeseries",
          "title": "Memory (Heap In-Use & RSS)",
          "id": 52,
          "gridPos": { "h": 8, "w": 8, "x": 8, "y": 47 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            { "refId": "A", "expr": "go_memstats_heap_inuse_bytes{job=\"static-pages\", cluster=~\"$cluster\", pod=~\"$pod\"}", "legendFormat": "heap {{pod}}" },
            { "refId": "B", "expr": "process_resident_memory_bytes{job=\"static-pages\", cluster=~\"$cluster\", pod=~\"$pod\"}", "legendFormat": "rss {{pod}}" }
          ],
          "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineWidth": 1 } }, "overrides": [] },
          "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
        },
        {
          "type": "timeseries",
          "title": "CPU Usage",
          "id": 53,
          "gridPos": { "h": 8, "w": 8, "x": 16, "y": 47 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            { "refId": "A", "expr": "rate(process_cpu_seconds_total{job=\"static-pages\", cluster=~\"$cluster\", pod=~\"$pod\"}[$__rate_interval])", "legendFormat": "{{pod}}" }
          ],
          "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineWidth": 1 } }, "overrides": [] },
          "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
        },
        {
          "type": "timeseries",
          "title": "GC Pause Rate",
          "id": 54,
          "gridPos": { "h": 7, "w": 8, "x": 0, "y": 55 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            { "refId": "A", "expr": "rate(go_gc_duration_seconds_sum{job=\"static-pages\", cluster=~\"$cluster\", pod=~\"$pod\"}[$__rate_interval])", "legendFormat": "{{pod}}" }
          ],
          "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineWidth": 1 } }, "overrides": [] },
          "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
        },
        {
          "type": "timeseries",
          "title": "File Descriptor Usage",
          "id": 55,
          "gridPos": { "h": 7, "w": 8, "x": 8, "y": 55 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            { "refId": "A", "expr": "process_open_fds{job=\"static-pages\", cluster=~\"$cluster\", pod=~\"$pod\"} / clamp_min(process_max_fds{job=\"static-pages\", cluster=~\"$cluster\", pod=~\"$pod\"}, 1)", "legendFormat": "{{pod}}" }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percentunit",
              "max": 1,
              "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineWidth": 1 },
              "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 } ] }
            },
            "overrides": []
          },
          "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
        },
        {
          "type": "timeseries",
          "title": "Process Uptime",
          "description": "Drops to zero indicate a restart/crashloop.",
          "id": 56,
          "gridPos": { "h": 7, "w": 8, "x": 16, "y": 55 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            { "refId": "A", "expr": "time() - process_start_time_seconds{job=\"static-pages\", cluster=~\"$cluster\", pod=~\"$pod\"}", "legendFormat": "{{pod}}" }
          ],
          "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineWidth": 1 } }, "overrides": [] },
          "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
        }
      ]
    }
  ]
}
