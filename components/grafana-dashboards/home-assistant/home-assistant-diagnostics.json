{
  "uid": "homeassistant-diagnostics",
  "title": "Home Assistant \u2014 Diagnostics",
  "tags": [
    "home-assistant",
    "infrastructure",
    "homelab"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "editable": true,
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "site",
        "label": "Site",
        "type": "custom",
        "query": "hass,hass-schiltach",
        "includeAll": false,
        "multi": false,
        "current": {
          "text": "hass",
          "value": "hass",
          "selected": true
        },
        "options": [
          {
            "text": "hass",
            "value": "hass",
            "selected": true
          },
          {
            "text": "hass-schiltach",
            "value": "hass-schiltach",
            "selected": false
          }
        ],
        "hide": 0
      },
      {
        "name": "level",
        "label": "Log level",
        "type": "custom",
        "query": "error,err,fatal,warn,warning,info,debug",
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Health & triage",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "HA scrape up",
      "description": "Is the Home Assistant Prometheus endpoint being scraped? Red = HA exporter down / ingest broken.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir-${site}"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 3,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bool_on_off",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir-${site}"
          },
          "expr": "max(up)",
          "refId": "A",
          "legendFormat": "",
          "instant": true,
          "format": "time_series"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total entities",
      "description": "Total entities exposed by Home Assistant.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir-${site}"
      },
      "gridPos": {
        "x": 3,
        "y": 1,
        "w": 3,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir-${site}"
          },
          "expr": "count(hass_entity_available)",
          "refId": "A",
          "legendFormat": "",
          "instant": true,
          "format": "time_series"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Unavailable entities",
      "description": "Entities currently reporting unavailable. The primary triage signal.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir-${site}"
      },
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "red",
                "value": 200
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir-${site}"
          },
          "expr": "count(hass_entity_available == 0)",
          "refId": "A",
          "legendFormat": "",
          "instant": true,
          "format": "time_series"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Availability",
      "description": "Share of entities currently available.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir-${site}"
      },
      "gridPos": {
        "x": 10,
        "y": 1,
        "w": 3,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 80
              },
              {
                "color": "yellow",
                "value": 90
              },
              {
                "color": "green",
                "value": 98
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir-${site}"
          },
          "expr": "100 * avg(hass_entity_available)",
          "refId": "A",
          "legendFormat": "",
          "instant": true,
          "format": "time_series"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Stale > 1h",
      "description": "Entities with a valid last-update timestamp older than 1h (epoch-0/never-updated entities excluded).",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir-${site}"
      },
      "gridPos": {
        "x": 13,
        "y": 1,
        "w": 3,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "orange",
                "value": 50
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir-${site}"
          },
          "expr": "count((time() - (hass_last_updated_time_seconds > 1.0e9)) > 3600)",
          "refId": "A",
          "legendFormat": "",
          "instant": true,
          "format": "time_series"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Log errors (1h)",
      "description": "Error-level log lines in the last hour (logs source).",
      "datasource": {
        "type": "loki",
        "uid": "loki-${site}"
      },
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 25
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-${site}"
          },
          "expr": "sum(count_over_time({service_name=\"homeassistant\"} | logfmt | level=~\"error|err|fatal\" [1h]))",
          "refId": "A",
          "legendFormat": "",
          "instant": true,
          "format": "time_series"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Automations / 5m",
      "description": "Automation triggers in the last 5 minutes (overall activity heartbeat).",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir-${site}"
      },
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir-${site}"
          },
          "expr": "sum(increase(hass_automation_triggered_count_total[5m]))",
          "refId": "A",
          "legendFormat": "",
          "instant": true,
          "format": "time_series"
        }
      ]
    },
    {
      "id": 9,
      "type": "row",
      "title": "Entity availability",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Available vs unavailable entities",
      "description": "Entity availability over time (stacked = total entities). A jump in 'unavailable' points to an integration/device outage.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir-${site}"
      },
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 30,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          },
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "available"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "unavailable"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir-${site}"
          },
          "expr": "count(hass_entity_available == 1)",
          "refId": "A",
          "legendFormat": "available",
          "format": "time_series"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir-${site}"
          },
          "expr": "count(hass_entity_available == 0)",
          "refId": "B",
          "legendFormat": "unavailable",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 11,
      "type": "piechart",
      "title": "Unavailable by domain",
      "description": "Which entity domains are unavailable. Concentration in one domain \u21d2 one integration is down.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir-${site}"
      },
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "pieType": "donut",
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "showLegend": false,
          "displayMode": "list",
          "placement": "right"
        },
        "displayLabels": [
          "value"
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir-${site}"
          },
          "expr": "count by (domain) (hass_entity_available == 0)",
          "refId": "A",
          "legendFormat": "{{domain}}",
          "instant": true,
          "format": "time_series"
        }
      ]
    },
    {
      "id": 12,
      "type": "table",
      "title": "Currently unavailable entities",
      "description": "The actionable list: every entity reporting unavailable right now.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir-${site}"
      },
      "gridPos": {
        "x": 18,
        "y": 6,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        }
      },
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "component": true,
              "hostname": true,
              "Value": true,
              "entity": true
            },
            "renameByName": {
              "friendly_name": "entity",
              "domain": "domain"
            },
            "indexByName": {
              "friendly_name": 0,
              "domain": 1
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir-${site}"
          },
          "expr": "hass_entity_available == 0",
          "refId": "A",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "id": 13,
      "type": "row",
      "title": "Staleness (entities not updating)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 14,
      "type": "table",
      "title": "Stalest entities",
      "description": "Entities with the oldest valid last-update time. High age = stuck sensor / dead integration (epoch-0 entities excluded).",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir-${site}"
      },
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "age (s)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 1800
                    },
                    {
                      "color": "red",
                      "value": 3600
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        },
        "sortBy": [
          {
            "displayName": "age (s)",
            "desc": true
          }
        ]
      },
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "component": true,
              "hostname": true,
              "entity": true
            },
            "renameByName": {
              "friendly_name": "entity",
              "domain": "domain",
              "Value": "age (s)",
              "hostname": "host"
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir-${site}"
          },
          "expr": "topk(25, time() - (hass_last_updated_time_seconds > 1.0e9))",
          "refId": "A",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Entities updated per minute (freshness)",
      "description": "How many entities pushed a fresh update in the last 5m window. A drop = HA stopped updating state.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir-${site}"
      },
      "gridPos": {
        "x": 12,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 20,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir-${site}"
          },
          "expr": "count(changes(hass_last_updated_time_seconds[5m]) > bool 0)",
          "refId": "A",
          "legendFormat": "entities updating",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 16,
      "type": "row",
      "title": "Environment & devices",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Temperatures",
      "description": "All temperature sensors.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir-${site}"
      },
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir-${site}"
          },
          "expr": "hass_sensor_temperature_celsius",
          "refId": "A",
          "legendFormat": "{{friendly_name}}",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 18,
      "type": "table",
      "title": "Low batteries",
      "description": "Lowest battery levels \u2014 replace these. Sorted ascending.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir-${site}"
      },
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 6,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
