{
  "uid": "hcloud-servers",
  "title": "Hetzner Cloud Servers",
  "description": "Hetzner Cloud fleet inventory, cost, traffic, and load balancer health. Metrics from promhippie hcloud_exporter.",
  "tags": [
    "hetzner",
    "infrastructure",
    "hcloud"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "1m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Data source",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1,
        "regex": "",
        "includeAll": false,
        "multi": false
      },
      {
        "name": "datacenter",
        "type": "query",
        "label": "Datacenter",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(hcloud_server_running, datacenter)",
        "query": {
          "query": "label_values(hcloud_server_running, datacenter)",
          "refId": "StandardVariableQuery"
        },
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 2,
        "sort": 1,
        "hide": 0
      },
      {
        "name": "server",
        "type": "query",
        "label": "Server",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(hcloud_server_running{datacenter=~\"$datacenter\"}, name)",
        "query": {
          "query": "label_values(hcloud_server_running{datacenter=~\"$datacenter\"}, name)",
          "refId": "StandardVariableQuery"
        },
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 2,
        "sort": 1,
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "type": "dashboard",
        "hide": true,
        "name": "Annotations & Alerts",
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
